FROM php:8.2-apache

RUN apt-get update && apt-get install -y \
        libzip-dev \
        libpng-dev \
        libjpeg-dev \
        libfreetype6-dev \
        libonig-dev \
        libxml2-dev \
        libssh2-1-dev \
        libssh2-1 \
        zip unzip git curl cron \
        mariadb-client \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install -j$(nproc) pdo_mysql mysqli zip gd mbstring exif pcntl bcmath \
    && pecl install ssh2-1.4.1 \
    && docker-php-ext-enable ssh2 \
    && a2enmod rewrite \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

COPY . /var/www/html/

RUN chown -R www-data:www-data /var/www/html \
    && chmod -R 755 /var/www/html \
    && chmod -R 777 /var/www/html/uploads \
    && chmod -R 777 /var/www/html/logs \
    && chmod -R 777 /var/www/html/backups

COPY docker/crontab.txt /etc/crontab
RUN chmod 0644 /etc/crontab

COPY docker/cron-scheduler.sh /usr/local/bin/cron-scheduler.sh
RUN chmod +x /usr/local/bin/cron-scheduler.sh

COPY docker/init.sh /usr/local/bin/init.sh
RUN chmod +x /usr/local/bin/init.sh

WORKDIR /var/www/html

EXPOSE 80

CMD ["sh", "-c", "/usr/local/bin/init.sh && cron && apache2-foreground"]